{
  "name": "@workspace/api-server",
  "version": "6.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "start": "node ./dist/index.cjs",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docs:openapi": "tsx ./src/scripts/generate-openapi.ts",
    "docs:lint": "redocly lint ../../docs/api/openapi.json",
    "rate-limit:inspect": "tsx ./src/scripts/rate-limit-tool.ts inspect",
    "rate-limit:reset": "tsx ./src/scripts/rate-limit-tool.ts reset",
    "seed": "tsx ./src/scripts/seed.ts",
    "db:seed:dummy-users": "tsx ./src/scripts/seed-dummy-users.ts",
    "db:export:launch-reference-profiles:v2:images": "tsx ./src/scripts/export-launch-reference-v2-image-manifest.ts",
    "db:seed:launch-reference-profiles": "tsx ./src/scripts/seed-launch-reference-profiles.ts",
    "db:seed:launch-reference-profiles:v2": "tsx ./src/scripts/seed-launch-reference-profiles-v2.ts",
    "db:validate:launch-reference-profiles": "tsx ./src/scripts/validate-launch-reference-profiles.ts",
    "db:validate:launch-reference-profiles:v2": "tsx ./src/scripts/validate-launch-reference-profiles-v2.ts",
    "db:refresh:launch-reference-profiles": "tsx ./src/scripts/refresh-launch-reference-profiles.ts",
    "db:refresh:launch-reference-profiles:v2": "tsx ./src/scripts/refresh-launch-reference-profiles-v2.ts",
    "db:seed:all": "pnpm seed && pnpm db:seed:dummy-users",
    "db:setup": "tsx ./src/scripts/db-setup.ts",
    "db:reset": "tsx ./src/scripts/db-reset.ts",
    "db:rebuild:preferences": "tsx ./src/scripts/rebuild-discovery-projections.ts",
    "db:rebuild:goal-targets": "tsx ./src/scripts/rebuild-goals-projections.ts",
    "db:rebuild:goals-projections": "tsx ./src/scripts/rebuild-goals-projections.ts",
    "db:rebuild:discovery-projections": "tsx ./src/scripts/rebuild-discovery-projections.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "nodemailer": "^8.0.5",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@redocly/cli": "^2.25.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^7.0.11",
    "core-js": "^3.49.0",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}
