# Application runtime
APP_NAME=Matcha
APP_ENV=development
APP_PORT=8082
API_BASE_URL=http://127.0.0.1:8082
FRONTEND_BASE_URL=http://localhost:8080
AUTH_FRONTEND_REDIRECT_URI=matcha:///auth-callback
AUTH_SESSION_SECRET=change-me
AUTH_ACCESS_TTL_MINUTES=43200
AUTH_REFRESH_TTL_DAYS=30
AUTH_PASSWORD_RESET_TTL_MINUTES=60
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_URL_BASE=http://localhost:8080/reset-password

# Local Postgres bootstrap
# Set INSTALL=true on your machine to auto-create the database.
INSTALL=false
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ignaciokaiser
DB_PASSWORD=
DB_NAME=matcha
DB_ADMIN_DB=postgres

# Optional direct URL override
# DATABASE_URL=postgresql://ignaciokaiser@127.0.0.1:5432/matcha

# Optional SMTP
SMTP_ENABLED=false
EMAIL_LOG_ONLY=false
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@matcha.local
SMTP_FROM_NAME=Matcha
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_VERIFY_ON_STARTUP=false

# Optional social providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_SERVICE_ID=
