# Application runtime
APP_NAME=Matcha
APP_ENV=development
APP_LOG_LEVEL=debug
APP_SERVICE_MODE=all
APP_PORT=8082
API_BASE_URL=http://127.0.0.1:8082
ADMIN_BASE_URL=http://127.0.0.1:8082
FRONTEND_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8082
ADMIN_CORS_ALLOWED_ORIGINS=
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_ADMIN_MAX=1200
RATE_LIMIT_ADMIN_WINDOW_MS=300000
AUTH_FRONTEND_REDIRECT_URI=matcha:///auth-callback
AUTH_SESSION_SECRET=<generate-a-strong-random-secret>
AUTH_ACCESS_TTL_MINUTES=43200
AUTH_REFRESH_TTL_DAYS=30
AUTH_PASSWORD_RESET_TTL_MINUTES=60
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_URL_BASE=http://localhost:8080/reset-password

# Local Postgres bootstrap
# Set INSTALL=true on your machine to auto-create the database.
INSTALL=false
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=matcha
DB_PASSWORD=<local-database-password>
DB_NAME=matcha
DB_ADMIN_DB=postgres

# Optional direct URL override
# DATABASE_URL=
# Example format: postgresql://matcha:<password>@127.0.0.1:5432/matcha

# Optional Redis-backed API cache. Leave CACHE_ENABLED=false or REDIS_URL blank
# to run without Redis. When Redis is unavailable, the API falls back to DB reads.
# REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_REDIS_ENABLED=false
CACHE_ENABLED=false
CACHE_DEFAULT_TTL_SECONDS=60

# Optional admin dashboard hardening
ADMIN_ALLOWED_CIDRS=127.0.0.1/32

# Optional SMTP
SMTP_ENABLED=false
EMAIL_LOG_ONLY=false
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=<smtp-password>
SMTP_FROM_EMAIL=no-reply@matcha.local
SMTP_FROM_NAME=Matcha
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_VERIFY_ON_STARTUP=false

# Optional social providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_SERVICE_ID=

# Optional local development account seed. Leave unset by default.
# SEED_DEFAULT_EMAIL=
# SEED_DEFAULT_PASSWORD=
