FROM node:22-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

FROM base AS builder
ARG EXPO_PUBLIC_AUTH_API_URL
ARG EXPO_PUBLIC_ADMIN_DASHBOARD_POLL_MS
ARG EXPO_PUBLIC_ANALYTICS_ENABLED
ARG EXPO_PUBLIC_ANALYTICS_DEBUG_LOGS
ARG EXPO_PUBLIC_ANALYTICS_HEARTBEAT_INTERVAL_SECONDS
ARG EXPO_PUBLIC_ANALYTICS_QUEUE_MAX_SIZE
ENV NODE_ENV=production
ENV EXPO_PUBLIC_AUTH_API_URL=${EXPO_PUBLIC_AUTH_API_URL}
ENV EXPO_PUBLIC_ADMIN_DASHBOARD_POLL_MS=${EXPO_PUBLIC_ADMIN_DASHBOARD_POLL_MS}
ENV EXPO_PUBLIC_ANALYTICS_ENABLED=${EXPO_PUBLIC_ANALYTICS_ENABLED}
ENV EXPO_PUBLIC_ANALYTICS_DEBUG_LOGS=${EXPO_PUBLIC_ANALYTICS_DEBUG_LOGS}
ENV EXPO_PUBLIC_ANALYTICS_HEARTBEAT_INTERVAL_SECONDS=${EXPO_PUBLIC_ANALYTICS_HEARTBEAT_INTERVAL_SECONDS}
ENV EXPO_PUBLIC_ANALYTICS_QUEUE_MAX_SIZE=${EXPO_PUBLIC_ANALYTICS_QUEUE_MAX_SIZE}
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --dir artifacts/matcha-app exec expo export --platform web --output-dir dist-web

FROM caddy:2.8-alpine AS runtime
COPY artifacts/matcha-app/Caddyfile.web /etc/caddy/Caddyfile
COPY --from=builder /app/artifacts/matcha-app/dist-web /srv
EXPOSE 3000
