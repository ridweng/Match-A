{
  "expo": {
    "name": "MatchA",
    "slug": "matcha-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "matcha",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1A14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.matcha.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "MatchA uses Face ID to unlock your account quickly and securely.",
        "NSLocationWhenInUseUsageDescription": "MatchA uses your location to show your current city on your profile."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F1A14"
      },
      "package": "com.matcha.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MatchA uses your location to show your current city on your profile."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1A14"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
