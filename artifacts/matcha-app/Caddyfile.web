:3000 {
  encode zstd gzip
  header {
    Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: http://localhost:* http://127.0.0.1:*; media-src 'self' https:; worker-src 'self' blob:"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy no-referrer
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Cross-Origin-Opener-Policy "same-origin-allow-popups"
    Cross-Origin-Resource-Policy "same-site"
  }
  @immutable {
    path /_expo/static/* /assets/* *.js *.css *.png *.jpg *.jpeg *.webp *.woff *.woff2
  }
  header @immutable Cache-Control "public, max-age=31536000, immutable"
  @notImmutable {
    not path /_expo/static/* /assets/* *.js *.css *.png *.jpg *.jpeg *.webp *.woff *.woff2
  }
  header @notImmutable Cache-Control "no-cache"
  root * /srv
  try_files {path} {path}/ {path}.html /index.html
  file_server
}
