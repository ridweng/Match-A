PORT=8082
NODE_ENV=development
AUTH_BASE_URL=http://localhost:8082
AUTH_FRONTEND_REDIRECT_URI=matcha://auth-callback
AUTH_SESSION_SECRET=change-me
AUTH_MINIMUM_AGE=18

# Optional MySQL configuration. If omitted, the backend uses a local JSON file
# store at ./data/auth-dev.json for development only.
# MYSQL_URL=mysql://user:password@localhost:3306/matcha_auth
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=matcha_auth

# Optional SMTP verification email transport.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASSWORD=password
# SMTP_FROM=MatchA <no-reply@example.com>

# OAuth provider configuration. If any provider is missing required values,
# the mobile app will show it as temporarily unavailable.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_SERVICE_ID=
