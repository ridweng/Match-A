POSTGRES_DB=matcha
POSTGRES_USER=matcha
POSTGRES_PASSWORD=<local-database-password>
DATABASE_URL=

API_BASE_URL=http://localhost:8082
FRONTEND_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8082
ADMIN_CORS_ALLOWED_ORIGINS=
AUTH_FRONTEND_REDIRECT_URI=matcha:///auth-callback
AUTH_PASSWORD_RESET_URL_BASE=http://localhost:8080/reset-password
AUTH_SESSION_SECRET=<generate-a-strong-random-secret>

ADMIN_DASHBOARD_ENABLED=true
ADMIN_BASIC_AUTH_USERNAME=<admin-username>
ADMIN_BASIC_AUTH_PASSWORD=<generate-a-strong-random-password>
ADMIN_ALLOWED_CIDRS=127.0.0.1/32

SMTP_ENABLED=true
EMAIL_LOG_ONLY=false
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@matcha.local
SMTP_FROM_NAME=Matcha

# Example format:
# DATABASE_URL=postgresql://matcha:<password>@postgres:5432/matcha

# Optional local development account seed. Leave unset by default.
# SEED_DEFAULT_EMAIL=
# SEED_DEFAULT_PASSWORD=
